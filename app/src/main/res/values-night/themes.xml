        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/green_primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/text_primary_dark</item>
        <item name="colorSecondary">@color/green_accent</item>
        <item name="colorSecondaryContainer">@color/surface_dark_alt</item>
        <item name="android:colorBackground">@color/screen_dark</item>
        <item name="colorSurface">@color/card_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_dark</item>
        <item name="colorOutline">@color/divider_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
